flights<-arrange(flights, dep_time)
flights
flights<-arrange(flights, year, month, day, dep_time)
distanceData<- flights %>%
group_by(tailnum) %>%
summarise(meanDist=mean(distance), numFlights = n())
distanceData <- arrange(distanceData, desc(meanDist))
distanceData
ggplot(data=distanceData, mapping=aes(x=meanDist, y=numFlights))+
geom_point(alpha=1/10)+
geom_smooth(se=FALSE)
flights
carrierData <- flights %>%
group_by(carrier) %>%
filter(n()>100)%>%
summarise(avgDistance = mean(distance))
carrierData
ggplot(data=carrierData, mapping=aes(x=carrier, y=avgDistance))+
geom_bar()
ggplot(data=carrierData, mapping=aes(x=carrier, y=avgDistance))+#
 geom_bar(stat="identity")
ggplot(data=carrierData, mapping=aes(x=carrier, y=avgDistance, color=carrier))+#
  geom_bar(stat="identity")
carrierData <- arrange(carrierData, avgDistance)
carrierData
ggplot(data=carrierData, mapping=aes(x=carrier, y=avgDistance, fill=carrier))+#
 geom_bar(stat="identity")
carrierData<- mutate(carrierData, carrier=fct_inorder(carrier))
ggplot(data=carrierData, mapping=aes(x=carrier, y=avgDistance, fill=carrier))+
geom_bar(stat="identity")
carrierData
library(tidyverse)
library(dplyr)
library(nycflights13)
flights
flightTime <- flights %>%
transmute(occured = !is.na(dep_time), time = dep_time) %>%
filter(dep_time>-1)
flightTimes <- flights %>%
transmute(occured = !is.na(dep_time), time=dep_time)
flightTimes
ggplot(data=flightTimes, mapping = aes(x=time, color = occured))+
geom_freqpoly(binwidth=1)
flightsJan <- filter(flights, month==1)
flightsJan
flightTime <- flightsJan %>%
transmute(cancelled = is.na(dep_time), time = dep_time)%>%
filter(time>0)
flightTime
ggplot(data=flightTime, mapping=aes(x=time))+
geom_freqpoly(mapping=aes(colour=cancelled), binwidth=1/4)
nycflights13::flights %>% #
  mutate(#
    cancelled = is.na(dep_time),#
    sched_hour = sched_dep_time %/% 100,#
    sched_min = sched_dep_time %% 100,#
    sched_dep_time = sched_hour + sched_min / 60#
  ) %>% #
  ggplot(mapping = aes(sched_dep_time)) + #
    geom_freqpoly(mapping = aes(colour = cancelled), binwidth = 1/4)
ggplot(data=flightTime, mapping=aes(time))+
geom_freqpoly(mapping=aes(color=cancelled), binwidth=1/4)

library(modelr)
mod<-lm(log(price)~log(carat), data=diamonds)
diamodns2<-diamonds %>%
add_residuals(mod) %>%
mutate(resid=exp(resid))
ggplot(data=diamonds2)+
geom_point(mapping=aes(x-carat, y=resid))
ggplot(data=diamodns2)+
geom_point(mapping=aes(x=carat, y=resid))
ggplot(data=diamonds)+
geom_point(mapping=aes(x=carat, y=resid))
ggplot(data=diamonds, mapping=aes(x=carat))+
geom_freqpoly(binwidth=0.25)
diamonds
diamondsCC <- diamonds %>%
group_by(color, clarity) %>%
summarise(mDepth = mean(depth), mPrice = mean(price))
diamondsCC
ggplot(data=diamondsCC, mapping=aes(x=color, y=clarity))+
geom_tile(aes(fill=mDepth))
ggplot(data=diamondsCC, mapping=aes(x=color, y=clarity))+
geom_tile(aes(fill=mPrice))
ggplot(data=diamondsCC, mapping=aes(x=reorder(color, mPrice, FUN=mean), y=clarity))+
geom_tile(aes(fill=mPrice))
diamondsCC<-arrange(diamondsCC, mPrice)
diamondsCC
ggplot(data=diamonds)+
geom_hex(mapping=aes(x=carat, y=price))
